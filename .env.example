# 数据库连接（开发本地用 Docker PostgreSQL）
# DATABASE_URL="postgresql://treasure:treasure@localhost:5432/treasure?schema=public"

# 线上部署用（Neon / Supabase，把实际地址填进来）
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# Session 密钥（生成方法：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"）
SESSION_SECRET="replace_me_with_a_64_char_random_hex_string"

# 种子管理员
SEED_ADMIN_USERNAME="admin"
SEED_ADMIN_PASSWORD="admin12345"
